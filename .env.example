# ═══════════════════════════════════════════════════════════════
# ProcureAdvisor — Environment Variables
# ═══════════════════════════════════════════════════════════════

# PostgreSQL (Supabase, Neon, or local)
DATABASE_URL="postgresql://user:password@host:5432/procure_advisor?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"

# n8n Webhook for ProcureBot AI
N8N_WEBHOOK_URL="https://your-n8n-instance.com/webhook/procurebot"

# n8n Basic Authentication
N8N_USER="your-n8n-username"
N8N_PASSWORD="your-n8n-password"

# Anthropic API (fallback direct if n8n unavailable)
ANTHROPIC_API_KEY=""
