# ═══════════════════════════════════════════════════════════════
# ProcureAdvisor — Environment Variables
# ═══════════════════════════════════════════════════════════════

# PostgreSQL Database (Supabase, Neon, Railway, or local)
# Example: postgresql://user:password@host:5432/procure_advisor?schema=public
DATABASE_URL=""

# NextAuth Configuration
# NEXTAUTH_URL: Your production URL on Vercel (auto-set by Vercel)
# NEXTAUTH_SECRET: Generate with `openssl rand -base64 32`
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET=""

# n8n Webhook for ProcureBot AI (optional)
N8N_WEBHOOK_URL=""

# n8n Basic Authentication (optional)
N8N_USER=""
N8N_PASSWORD=""

# Anthropic API Key (fallback if n8n unavailable)
ANTHROPIC_API_KEY=""
