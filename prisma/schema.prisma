generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id         String   @id
  userId     String?
  userName   String?
  action     String
  module     String?
  entityId   String?
  details    String?
  aiInvolved Boolean  @default(false)
  createdAt  DateTime @default(now())
  user       User?    @relation(fields: [userId], references: [id])
}

model AlternativeSupplier {
  id              String            @id
  categoryId      String
  name            String
  country         String
  city            String?
  currency        String            @default("USD")
  contactName     String?
  contactEmail    String?
  status          AltSupplierStatus @default(identified)
  evaluation      Json?
  relevanceScore  Int               @default(50)
  comparisonNotes String?
  discoveryDate   DateTime          @default(now())
  lastContactDate DateTime?
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
}

model Anomaly {
  id                              String        @id
  category                        String
  subCategory                     String?
  severity                        Severity
  priority                        Int           @default(3)
  title                           String
  description                     String?
  detectionMethod                 String?
  ruleId                          String?
  supplierId                      String?
  userId                          String?
  poleId                          String?
  orderId                         String?
  financialImpact                 Float?
  dateDetected                    DateTime
  dateResolved                    DateTime?
  status                          AnomalyStatus @default(open)
  resolutionNotes                 String?
  resolvedById                    String?
  isDeleted                       Boolean       @default(false)
  createdAt                       DateTime      @default(now())
  updatedAt                       DateTime
  order      Order?    @relation(fields: [orderId], references: [id])
  resolvedBy User?     @relation("Anomaly_resolvedByIdToUser", fields: [resolvedById], references: [id])
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  user       User?     @relation("Anomaly_userIdToUser", fields: [userId], references: [id])
}

model Article {
  id                    String        @id
  code                  String        @unique
  designation           String
  familyId              String
  unit                  String        @default("kg")
  poleIds               String[]
  supplierIds           String[]
  criticalLevel         CriticalLevel @default(standard)
  safetyStockDays       Int           @default(15)
  avgMonthlyConsumption Float         @default(0)
  currentStock          Float         @default(0)
  x3Id                  String?
  isDeleted             Boolean       @default(false)
  createdAt             DateTime      @default(now())
  updatedAt             DateTime
  orderLines OrderLine[]
}

model AuditRule {
  id       String   @id
  code     String   @unique
  name     String
  category String
  severity Severity
  isActive Boolean  @default(true)
}

model Document {
  id                               String               @id
  fileName                         String
  fileSize                         String?
  fileType                         String               @default("invoice")
  mimeType                         String?
  uploadDate                       DateTime             @default(now())
  uploadedById                     String
  assignedToId                     String?
  supplierId                       String?
  invoiceNumber                    String?
  poNumber                         String?
  amountHt                         Float?
  amountTva                        Float?
  amountTtc                        Float?
  ocrStatus                        OcrStatus            @default(pending)
  ocrConfidence                    Float?
  pipelineStage                    Int                  @default(1)
  reconciliationStatus             ReconciliationStatus @default(pending)
  variances                        Json?
  comments                         Json?
  isDeleted                        Boolean              @default(false)
  createdAt                        DateTime             @default(now())
  updatedAt                        DateTime
  ocrRawText                       String?
  folderId                         String?
  ocrFullText                      String?
  assignedTo User?     @relation("Document_assignedToIdToUser", fields: [assignedToId], references: [id])
  folder     Folder?   @relation(fields: [folderId], references: [id])
  supplier   Supplier? @relation(fields: [supplierId], references: [id])
  uploadedBy User      @relation("Document_uploadedByIdToUser", fields: [uploadedById], references: [id])

  @@index([folderId])
}

model Folder {
  id           String     @id
  name         String
  description  String?
  color        String?    @default("#3B82F6")
  icon         String?    @default("folder")
  parentId     String?
  createdById  String
  isDeleted    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime
  report       Json?
  reportReady  Boolean    @default(false)
  reportStatus String     @default("idle")
  documents Document[]
  createdBy User      @relation(fields: [createdById], references: [id])
  parent    Folder?   @relation("FolderToFolder", fields: [parentId], references: [id])
  children  Folder[]  @relation("FolderToFolder")

  @@index([createdById])
  @@index([parentId])
}

model Invoice {
  id                 String        @id
  invoiceNumber      String        @unique
  supplierId         String
  dateInvoice        DateTime
  dateReceived       DateTime?
  dateDue            DateTime?
  amountHt           Float
  amountTva          Float         @default(0)
  amountTtc          Float
  currency           String        @default("XAF")
  orderId            String?
  status             InvoiceStatus @default(pending)
  isDuplicateSuspect Boolean       @default(false)
  isDeleted          Boolean       @default(false)
  createdAt          DateTime      @default(now())
  updatedAt          DateTime
  order    Order?   @relation(fields: [orderId], references: [id])
  supplier Supplier @relation(fields: [supplierId], references: [id])
}

model Letter {
  id          String       @id
  type        LetterType
  supplierId  String?
  subject     String
  tone        String       @default("diplomatic")
  status      LetterStatus @default(draft)
  generatedBy String       @default("manual")
  body        String
  createdById String
  isDeleted   Boolean      @default(false)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime
  createdBy User      @relation(fields: [createdById], references: [id])
  supplier  Supplier? @relation(fields: [supplierId], references: [id])
}

model Negotiation {
  id              String            @id
  supplierId      String?
  subject         String
  category        String?
  dateStart       DateTime
  dateDeadline    DateTime?
  dateClosed      DateTime?
  financialStake  Float             @default(0)
  targetSavings   Float             @default(0)
  achievedSavings Float?
  status          NegotiationStatus @default(preparation)
  strategy        String?
  rounds          Json?
  isDeleted       Boolean           @default(false)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime
  supplier Supplier? @relation(fields: [supplierId], references: [id])
}

model Notification {
  id                String    @id
  userId            String?
  title             String
  message           String
  severity          Severity  @default(info)
  isRead            Boolean   @default(false)
  readAt            DateTime?
  relatedEntityType String?
  relatedEntityId   String?
  createdAt         DateTime  @default(now())
  user User? @relation(fields: [userId], references: [id])
}

model Order {
  id             String       @id
  poNumber       String       @unique
  supplierId     String
  poleId         String
  dateCreated    DateTime
  dateExpected   DateTime
  dateReceived   DateTime?
  totalAmount    Float
  currency       String       @default("XAF")
  status         OrderStatus  @default(created)
  isLate         Boolean      @default(false)
  delayDays      Int          @default(0)
  riskOfStockout Boolean      @default(false)
  x3Id           String?
  x3SyncStatus   X3SyncStatus @default(synced)
  isDeleted      Boolean      @default(false)
  createdAt      DateTime     @default(now())
  updatedAt      DateTime
  anomalies  Anomaly[]
  invoices   Invoice[]
  supplier   Supplier   @relation(fields: [supplierId], references: [id])
  orderLines OrderLine[]
}

model OrderLine {
  id          String   @id
  orderId     String
  articleId   String?
  description String
  quantity    Float
  unitPrice   Float
  totalPrice  Float
  unit        String   @default("kg")
  article Article? @relation(fields: [articleId], references: [id])
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model Permission {
  id             String           @id
  code           String           @unique
  name           String
  description    String?
  category       String
  isSystem       Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  rolePermissions RolePermission[]
}

model Pole {
  id        String  @id
  code      String  @unique
  name      String
  color     String
  managerId String?
}

model PurchaseCategory {
  id       String     @id
  code     String     @unique
  name     String     @unique
  families String[]
  suppliers Supplier[]
}

model QuoteComparison {
  id          String      @id
  subject     String
  dateCreated DateTime    @default(now())
  createdById String?
  status      String      @default("active")
  isDeleted   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime
  quoteLines QuoteLine[]
}

model QuoteLine {
  id              String          @id
  comparisonId    String
  supplierId      String?
  supplierName    String
  unitPrice       Float
  landedCost      Float
  freightCost     Float           @default(0)
  moq             String?
  leadTime        Int             @default(0)
  incoterm        String?
  paymentTerms    String?
  certifications  String[]
  tco             Float           @default(0)
  score           Int             @default(50)
  reco            String?
  comparison QuoteComparison @relation(fields: [comparisonId], references: [id], onDelete: Cascade)
  supplier   Supplier?      @relation(fields: [supplierId], references: [id])
}

model RawMaterial {
  id            String    @id
  name          String
  category      String
  unit          String
  currency      String    @default("USD")
  currentPrice  Float
  previousPrice Float
  variationPct  Float     @default(0)
  trend         Trend     @default(stable)
  impactedPoles String[]
  alertType     AlertType @default(neutral)
  isDeleted     Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime
}

model Role {
  id             String           @id
  code           String           @unique
  name           String
  description    String?
  isSystem       Boolean          @default(false)
  isDefault      Boolean          @default(false)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime
  rolePermissions RolePermission[]
  users           User[]
}

model RolePermission {
  roleId       String
  permissionId String
  createdAt    DateTime   @default(now())
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Setting {
  id    String @id
  key   String @unique
  value Json
}

model Supplier {
  id               String           @id
  code             String           @unique
  name             String
  country          String
  city             String?
  currency         String           @default("XAF")
  categoryId       String
  status           SupplierStatus   @default(active)
  riskLevel        RiskLevel        @default(low)
  scoreGlobal      Int              @default(50)
  scoreQuality     Int              @default(50)
  scorePrice       Int              @default(50)
  scoreDelivery    Int              @default(50)
  scoreDoc         Int              @default(50)
  scoreReactivity  Int              @default(50)
  scoreRegularity  Int              @default(50)
  trend            Trend            @default(stable)
  dependencyRatio  Float            @default(0)
  volumeYtd        Float            @default(0)
  incidentsCount   Int              @default(0)
  anomaliesCount   Int              @default(0)
  incotermDefault  String?
  paymentTerms     String?
  contactName      String?
  contactEmail     String?
  contactPhone     String?
  certifications   String[]
  avgLeadTimeDays  Int              @default(0)
  contractRef      String?
  contractExpiry   DateTime?
  x3Id             String?
  x3SyncStatus     X3SyncStatus     @default(synced)
  isDeleted        Boolean          @default(false)
  createdAt        DateTime         @default(now())
  updatedAt        DateTime
  anomalies    Anomaly[]
  documents    Document[]
  invoices     Invoice[]
  letters      Letter[]
  negotiations Negotiation[]
  orders       Order[]
  quoteLines   QuoteLine[]
  category     PurchaseCategory @relation(fields: [categoryId], references: [id])
}

model User {
  id                                   String         @id
  username                             String         @unique
  passwordHash                         String
  fullName                             String
  email                                String         @unique
  avatar                               String
  poleIds                              String[]
  isActive                             Boolean        @default(true)
  loginCount                           Int            @default(0)
  lastLoginAt                          DateTime?
  createdAt                            DateTime       @default(now())
  updatedAt                            DateTime
  roleId                               String?
  activityLogs      ActivityLog[]
  resolvedAnomalies Anomaly[]      @relation("Anomaly_resolvedByIdToUser")
  anomalies         Anomaly[]      @relation("Anomaly_userIdToUser")
  assignedDocuments Document[]     @relation("Document_assignedToIdToUser")
  uploadedDocuments Document[]     @relation("Document_uploadedByIdToUser")
  folders           Folder[]
  letters           Letter[]
  notifications     Notification[]
  role              Role?          @relation(fields: [roleId], references: [id])
}

enum AlertType {
  opportunity
  risk
  neutral
}

enum AltSupplierStatus {
  identified
  to_contact
  in_discussion
  qualified
  in_test
  rejected
}

enum AnomalyStatus {
  open
  investigating
  escalated
  resolved
  dismissed
}

enum CriticalLevel {
  vital
  critical
  important
  standard
}

enum InvoiceStatus {
  pending
  approved
  disputed
  blocked
  paid
}

enum LetterStatus {
  draft
  ready
  sent
  archived
}

enum LetterType {
  price_dispute
  credit_request
  delivery_reminder
  rfq
  certificate_request
  formal_notice
  contract_reminder
  clarification
}

enum NegotiationStatus {
  preparation
  in_progress
  pending_decision
  closed_won
  closed_lost
  cancelled
}

enum OcrStatus {
  pending
  processing
  extracted
  failed
  partial
}

enum OrderStatus {
  created
  validated
  confirmed
  in_transit
  partially_received
  received
  closed
}

enum ReconciliationStatus {
  pending
  conforme
  ecart_mineur
  ecart_majeur
  critical
  validated
}

enum RiskLevel {
  critical
  high
  medium
  low
}

enum Severity {
  critical
  high
  medium
  low
  info
}

enum SupplierStatus {
  active
  probation
  suspended
  blocked
  strategic
  backup
  to_replace
}

enum Trend {
  rising
  stable
  declining
}

enum X3SyncStatus {
  synced
  conflict
  not_linked
}
